# Copy to .env and set as needed. All variables are optional.

# HuggingFace: token for private models and higher rate limits.
# Get one at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxx

# Weights & Biases: set to "disabled" or "offline" to skip W&B when not logged in.
# WANDB_MODE=disabled

# HuggingFace cache dirs (optional). Defaults to ~/.cache/huggingface
# HF_HOME=./cache/hf
# HF_DATASETS_CACHE=./cache/hf/datasets
# TRANSFORMERS_CACHE=./cache/hf/transformers
